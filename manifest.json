{
  "dxt_version": "0.1",
  "name": "omnifocus-mcp",
  "version": "1.0.0",
  "description": "OmniFocus integration via MCP",
  "author": {
    "name": "Nelson"
  },
  "server": {
    "type": "node",
    "entry_point": "src/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/src/index.js"],
      "env": {}
    }
  },
  "display_name": "OmniFocus MCP",
  "long_description": "Integrate OmniFocus task management through the Model Context Protocol. Provides CRUD operations for tasks, projects, folders, and contexts/tags.",
  "keywords": ["omnifocus", "gtd", "tasks", "productivity", "mcp"],
  "license": "MIT",
  "compatibility": {
    "platforms": ["darwin"]
  },
  "tools": [
    { "name": "get_tasks", "description": "Get tasks with optional filters" },
    { "name": "get_task", "description": "Get a task with all subtasks" },
    { "name": "create_task", "description": "Create a new task" },
    { "name": "update_task", "description": "Update an existing task" },
    { "name": "complete_task", "description": "Mark a task as completed" },
    { "name": "delete_task", "description": "Delete a task" },
    { "name": "get_tasks_by_date", "description": "Filter tasks by date criteria" },
    { "name": "get_projects", "description": "Get all projects" },
    { "name": "get_project", "description": "Get a project with all tasks" },
    { "name": "create_project", "description": "Create a new project" },
    { "name": "update_project", "description": "Update a project" },
    { "name": "complete_project", "description": "Mark a project as completed" },
    { "name": "delete_project", "description": "Delete a project" },
    { "name": "get_contexts", "description": "Get all contexts/tags" },
    { "name": "create_context", "description": "Create a new context/tag" },
    { "name": "update_context", "description": "Update a context/tag" },
    { "name": "delete_context", "description": "Delete a context/tag" },
    { "name": "get_folders", "description": "Get all folders" },
    { "name": "create_folder", "description": "Create a new folder" },
    { "name": "update_folder", "description": "Update a folder" },
    { "name": "delete_folder", "description": "Delete a folder" }
  ]
}
