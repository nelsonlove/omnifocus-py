# Obsidian Configuration
OBSIDIAN_API_KEY=your-api-key-from-obsidian
OBSIDIAN_API_URL=http://localhost:27124
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# You can get the API key from Obsidian:
# 1. Open Obsidian
# 2. Go to Settings → Community plugins → Local REST API
# 3. Copy the API key from there